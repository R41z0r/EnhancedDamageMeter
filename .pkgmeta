package-as: EnhancedDamageMeter

enable-nolib-creation: no

ignore:
  - .DS_Store
  - .env
  - .git
  - .github
  - .gitignore
  - .luacheckrc
  - build
  - libs
  - source
  - scripts
  - Core.lua
  - EnhancedDamageMeter.toc
  - Functions.lua
  - Icons
  - Settings.lua

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
